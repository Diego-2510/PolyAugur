# PolyAugur Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required: Mistral AI API Key (https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Custom DB path (default: data/signals.db)
# SIGNAL_DB_PATH=data/signals.db
